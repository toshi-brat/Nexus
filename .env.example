# ─────────────────────────────────────────────────────────────────────────────
# NEXUS Trading System — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── IndMoney / INDstocks ──────────────────────────────────────────────────────
# 1. Visit: https://www.indstocks.com/app/api-trading
# 2. Login with your registered mobile number (OTP)
# 3. Click "New Token" → copy token here
# 4. Click the hexagon icon → whitelist your server's static IP
# ⚠️  Token expires every 24 hours — regenerate daily!
INDMONEY_ACCESS_TOKEN=your_indmoney_access_token_here

# ── Zerodha Kite (optional) ───────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REQUEST_TOKEN=

# ── Upstox (optional) ─────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# ── Reddit (for sentiment) ─────────────────────────────────────────────────────
# Register app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NEXUS/1.0

# ── Twitter/X (for sentiment) ──────────────────────────────────────────────────
# Bearer token from: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# Database
DATABASE_URL=sqlite:///./data/nexus.db

# ─────────────────────────────────────────────────────────────────────────────
# NEXUS Trading System — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000
USE_DEMO_DATA=false

# ── IndMoney / INDstocks ──────────────────────────────────────────────────────
# 1. Visit: https://www.indstocks.com/app/api-trading
# 2. Login with your registered mobile number (OTP)
# 3. Click "New Token" → copy token here
# 4. Click the hexagon icon → whitelist your server's static IP
# ⚠️  Token expires every 24 hours — regenerate daily!
INDMONEY_ACCESS_TOKEN=your_indmoney_access_token_here

# ── Reddit (for sentiment) ─────────────────────────────────────────────────────
# Register app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NEXUS/1.0

# ── Twitter/X (for sentiment) ──────────────────────────────────────────────────
# Bearer token from: https://developer.twitter.com
TWITTER_BEARER_TOKEN=

# ── News enrichment (optional) ────────────────────────────────────────────────
# NewsAPI docs: https://newsapi.org/docs/endpoints/everything
# Target scope for this project: Indian equities, especially NSE and BSE.
# Official exchange RSS pages:
# NSE: https://www.nseindia.com/rss-feed
# BSE: https://www.bseindia.com/rss-feed.html
NEWS_API_KEY=
NEWS_QUERY=NSE OR BSE OR NIFTY OR BANKNIFTY OR SENSEX OR Bombay Stock Exchange OR National Stock Exchange OR Indian stock market

# Extra RSS feeds: Name|URL;Name|URL
# Example:
# ADDITIONAL_RSS_FEEDS=NSE Circulars|https://nsearchives.nseindia.com/content/RSS/circular_rss.xml;BSE Corporate Announcements|<paste BSE RSS URL here>
ADDITIONAL_RSS_FEEDS=

# TradingView MCP (optional)
TRADINGVIEW_MCP_URL=http://localhost:3001

# Database
DATABASE_URL=sqlite:///./data/nexus.db
